---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { fetchPosts } from '../../data/blog';
import { buildBreadcrumbSchema } from '../../lib/schema';

const posts = await fetchPosts();

const breadcrumbs = [
  { name: 'Inicio', url: '/' },
  { name: 'Blog', url: '/blog' },
];

const schemas = [buildBreadcrumbSchema(breadcrumbs)];

const sportLabels: Record<string, string> = {
  surf: 'Surf',
  kitesurf: 'Kitesurf',
  'wing-foil': 'Wing Foil',
  sup: 'SUP',
};
---

<BaseLayout
  title="Blog | Ola y Viento"
  description="Artículos sobre surf, kitesurf, wing foil y deportes náuticos en Barranquilla y el Caribe colombiano."
  canonical="/blog"
  schemas={schemas}
>
  <Header />
  <main id="main-content" class="pt-20">
    <!-- Breadcrumb -->
    <nav class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-4" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-sm text-gray-500">
        <li><a href="/" class="hover:text-brand-blue transition-colors">Inicio</a></li>
        <li><span class="mx-1">/</span></li>
        <li><span class="text-brand-dark font-medium">Blog</span></li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="py-12 sm:py-16 bg-gradient-to-br from-brand-blue to-brand-blue/80">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">
          Blog
        </h1>
        <p class="text-white/90 text-lg max-w-2xl mx-auto">
          Consejos, guías y novedades sobre surf, kitesurf, wing foil y la vida náutica en Barranquilla.
        </p>
      </div>
    </section>

    <!-- Posts Grid -->
    <section class="py-16 sm:py-20 bg-white">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        {posts.length === 0 ? (
          <p class="text-center text-gray-500 text-lg py-12">
            Próximamente publicaremos artículos. ¡Vuelve pronto!
          </p>
        ) : (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {posts.map(post => (
              <a
                href={`/blog/${post.slug}`}
                class="group bg-white rounded-2xl border border-gray-200 overflow-hidden hover:shadow-lg hover:border-brand-blue/30 transition-all"
              >
                {post.mainImage ? (
                  <div class="aspect-video overflow-hidden">
                    <img
                      src={post.mainImage}
                      alt={post.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </div>
                ) : (
                  <div class="aspect-video bg-gradient-to-br from-brand-blue/20 to-brand-yellow/20 flex items-center justify-center">
                    <svg class="w-12 h-12 text-brand-blue/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                    </svg>
                  </div>
                )}
                <div class="p-5">
                  <div class="flex items-center gap-2 mb-3">
                    <time class="text-xs text-gray-400" datetime={post.publishedAt}>
                      {new Date(post.publishedAt).toLocaleDateString('es-CO', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                    {post.sportSlug && (
                      <span class="text-xs bg-brand-blue/10 text-brand-blue px-2 py-0.5 rounded-full font-medium">
                        {sportLabels[post.sportSlug] || post.sportSlug}
                      </span>
                    )}
                  </div>
                  <h2 class="font-display font-bold text-brand-dark group-hover:text-brand-blue transition-colors mb-2 line-clamp-2">
                    {post.title}
                  </h2>
                  {post.excerpt && (
                    <p class="text-gray-500 text-sm line-clamp-3">{post.excerpt}</p>
                  )}
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
