---
const months = [
  { name: 'Ene', wind: 'high' },
  { name: 'Feb', wind: 'high' },
  { name: 'Mar', wind: 'high' },
  { name: 'Abr', wind: 'high' },
  { name: 'May', wind: 'low' },
  { name: 'Jun', wind: 'medium' },
  { name: 'Jul', wind: 'medium' },
  { name: 'Ago', wind: 'medium' },
  { name: 'Sep', wind: 'low' },
  { name: 'Oct', wind: 'low' },
  { name: 'Nov', wind: 'low' },
  { name: 'Dic', wind: 'high' },
];

const windColors: Record<string, string> = {
  high: 'bg-brand-orange text-white',
  medium: 'bg-brand-yellow text-brand-dark',
  low: 'bg-gray-200 text-gray-500',
};

const windLabels: Record<string, string> = {
  high: 'Fuerte',
  medium: 'Medio',
  low: 'Suave',
};

const windTooltips: Record<string, string> = {
  high: 'Viento fuerte, perfecto para kitesurf',
  medium: 'Viento moderado, bueno para windsurf y wing foil',
  low: 'Viento suave, ideal para SUP y surf',
};

const windIcons: Record<string, string> = {
  high: `<svg width="28" height="18" viewBox="0 0 28 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 3c4-2 8 2 12 0s8-2 12 0"/><path d="M2 9c4-2 8 2 12 0s8-2 12 0"/><path d="M2 15c4-2 8 2 12 0s8-2 12 0"/></svg>`,
  medium: `<svg width="28" height="18" viewBox="0 0 28 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 6c4-2 8 2 12 0s8-2 12 0"/><path d="M2 12c4-2 8 2 12 0s8-2 12 0"/></svg>`,
  low: `<svg width="28" height="18" viewBox="0 0 28 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 9c4-2 8 2 12 0s8-2 12 0"/></svg>`,
};
---

<section class="py-16 sm:py-24 bg-gray-50">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-brand-dark mb-3">
        Temporada de <span class="text-brand-orange">Viento</span>
      </h2>
      <p class="text-gray-600 max-w-2xl mx-auto">
        Barranquilla ofrece dos temporadas de viento al año. Planifica tu experiencia en el mejor momento.
      </p>
    </div>

    <!-- Calendar Grid -->
    <div class="grid grid-cols-4 sm:grid-cols-6 lg:grid-cols-12 gap-2 sm:gap-3 mb-8">
      {months.map(month => (
        <div class={`group relative rounded-xl p-3 sm:p-4 text-center ${windColors[month.wind]} transition-transform hover:scale-105 cursor-default`}>
          <div class="font-display font-bold text-sm sm:text-base">{month.name}</div>
          <div class="flex justify-center mt-1.5" set:html={windIcons[month.wind]} />
          <div class="text-[10px] sm:text-xs mt-1 opacity-75 font-medium">{windLabels[month.wind]}</div>
          <!-- Tooltip -->
          <div class="pointer-events-none absolute left-1/2 -translate-x-1/2 bottom-full mb-2 w-44 rounded-lg bg-brand-dark text-white text-xs px-3 py-2 opacity-0 group-hover:opacity-100 transition-opacity z-10 text-center shadow-lg">
            {windTooltips[month.wind]}
            <div class="absolute left-1/2 -translate-x-1/2 top-full w-0 h-0 border-l-4 border-r-4 border-t-4 border-transparent border-t-brand-dark"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Legend -->
    <div class="flex flex-wrap justify-center gap-4 sm:gap-6 text-sm text-gray-600">
      <div class="flex items-center gap-2">
        <div class="w-4 h-4 rounded bg-brand-orange"></div>
        <div class="text-brand-orange flex items-center" set:html={windIcons.high} />
        <span>Fuerte — kitesurf</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-4 h-4 rounded bg-brand-yellow"></div>
        <div class="text-brand-yellow flex items-center" set:html={windIcons.medium} />
        <span>Moderado — windsurf, wing foil</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-4 h-4 rounded bg-gray-200"></div>
        <div class="text-gray-400 flex items-center" set:html={windIcons.low} />
        <span>Suave — SUP, surf</span>
      </div>
    </div>

    <p class="text-center text-gray-500 text-sm mt-6">
      El surf funciona todo el año. Las mejores olas llegan de diciembre a marzo.
    </p>
  </div>
</section>
