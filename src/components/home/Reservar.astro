---

<section id="reservar" class="py-16 sm:py-24 bg-brand-yellow/10">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-brand-dark mb-3">
        Reserva tu <span class="text-brand-orange">Clase</span>
      </h2>
      <p class="text-gray-600 max-w-xl mx-auto">
        Elige tu deporte, fecha y horario. Todos los equipos están incluidos.
      </p>
    </div>

    <!-- AgendaPro Embed -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
      <iframe
        src="https://olayviento.site.agendapro.com/co"
        width="100%"
        height="700"
        frameborder="0"
        loading="lazy"
        title="Reservar clase en Ola y Viento"
        class="w-full min-h-[500px] sm:min-h-[700px]"
      ></iframe>
    </div>

    <p class="text-center text-gray-500 text-sm mt-4">
      ¿Prefieres WhatsApp?
      <a
        href="https://wa.me/573150031693?text=Hola%2C%20quiero%20reservar%20una%20clase"
        target="_blank"
        rel="noopener noreferrer"
        class="text-brand-blue hover:underline font-medium"
      >
        Escríbenos aquí
      </a>
    </p>
  </div>
</section>
