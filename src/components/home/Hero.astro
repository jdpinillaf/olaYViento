---
---

<section class="relative min-h-[100dvh] flex items-center justify-center overflow-hidden">
  <!-- Background gradient (replace with real image later) -->
  <div class="absolute inset-0 bg-gradient-to-br from-brand-blue via-brand-blue/80 to-brand-dark">
    <!-- Decorative spirals -->
    <img src="/images/spirals/amarillo-blanco.png" alt="" aria-hidden="true" class="absolute top-10 left-10 w-40 h-40 opacity-20 pointer-events-none" />
    <img src="/images/spirals/naranja-blanco.png" alt="" aria-hidden="true" class="absolute bottom-20 right-10 w-56 h-56 opacity-15 pointer-events-none" />
    <!-- Wave decoration at bottom -->
    <svg class="absolute bottom-0 left-0 right-0 w-full" viewBox="0 0 1440 120" fill="white" preserveAspectRatio="none">
      <path d="M0,60 C360,120 720,0 1080,60 C1260,90 1380,80 1440,70 L1440,120 L0,120 Z" />
    </svg>
  </div>

  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto pt-20 pb-32">
    <!-- Logo -->
    <div class="mb-6">
      <img src="/images/logo-icon.png" alt="Ola y Viento" width="96" height="96" class="h-20 sm:h-24 mx-auto drop-shadow-lg" />
    </div>

    <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-4">
      Aprende Surf, Paddle Surf, Kitesurf y Wing Foil en
      <span class="text-brand-yellow">Barranquilla</span>
    </h1>

    <p class="text-lg sm:text-xl text-white/90 max-w-2xl mx-auto mb-8 leading-relaxed">
      Escuela de deportes náuticos en la Costa Caribe de Colombia.
      Instructores certificados, equipos incluidos, todos los niveles.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#reservar"
        data-track="Reservar Click"
        data-track-location="hero_primary"
        class="bg-brand-orange hover:bg-brand-orange/90 text-white font-bold px-8 py-4 rounded-full text-lg transition-all hover:shadow-xl hover:scale-105 inline-flex items-center justify-center gap-2"
      >
        Reserva tu Clase
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a
        href="#deportes"
        data-track="Nav Click"
        data-track-location="hero_secondary"
        data-track-label="Ver Deportes"
        class="border-2 border-white/50 hover:border-white text-white font-semibold px-8 py-4 rounded-full text-lg transition-all hover:bg-white/10 inline-flex items-center justify-center"
      >
        Ver Deportes
      </a>
    </div>

    <!-- Trust indicators -->
    <div class="mt-12 flex flex-wrap justify-center gap-6 text-white/70 text-sm">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-brand-yellow" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
        Instructores Certificados
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-brand-yellow" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        Equipos Incluidos
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-brand-yellow" fill="currentColor" viewBox="0 0 20 20">
          <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/>
        </svg>
        Todos los Niveles
      </div>
    </div>
  </div>
</section>
