---
const navItems = [
  { label: 'Inicio', href: '/' },
  { label: 'Deportes', href: '/#deportes' },
  { label: 'Nosotros', href: '/#nosotros' },
  { label: 'Galería', href: '/#galeria' },
  { label: 'Contacto', href: '/#ubicacion' },
  { label: 'Blog', href: '/blog' },
];
---

<!-- Header: starts with white bg for readability, gets shadow on scroll -->
<header class="fixed top-0 left-0 right-0 z-40 transition-all duration-300 bg-white/90 backdrop-blur-md" id="main-header">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16 sm:h-20">
    <!-- Logo -->
    <a href="/" class="shrink-0">
      <img src="/images/logo-horizontal.png" alt="Ola y Viento" class="h-14 sm:h-16 w-auto" />
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-6">
      {navItems.map(item => (
        <a href={item.href} class="text-sm font-medium text-brand-dark/80 hover:text-brand-blue transition-colors">
          {item.label}
        </a>
      ))}
      <a
        href="/#reservar"
        class="bg-brand-orange hover:bg-brand-orange/90 text-white font-semibold px-5 py-2.5 rounded-full text-sm transition-all hover:shadow-lg"
      >
        Reserva tu Clase
      </a>
    </div>

    <!-- Mobile Menu Toggle -->
    <button
      id="menu-toggle"
      class="md:hidden p-2 text-brand-dark"
      aria-label="Abrir menú"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white/95 backdrop-blur-md border-t border-gray-100">
    <div class="px-4 py-4 space-y-3">
      {navItems.map(item => (
        <a href={item.href} class="block text-brand-dark/80 hover:text-brand-blue font-medium py-2 mobile-nav-link">
          {item.label}
        </a>
      ))}
      <a
        href="/#reservar"
        class="block bg-brand-orange text-white text-center font-semibold px-5 py-3 rounded-full mt-4 mobile-nav-link"
      >
        Reserva tu Clase
      </a>
    </div>
  </div>
</header>

<!-- Floating Reservar CTA (appears on scroll past hero) -->
<div id="floating-cta" class="fixed bottom-20 left-1/2 -translate-x-1/2 z-40 opacity-0 pointer-events-none transition-all duration-300 translate-y-4">
  <a
    href="/#reservar"
    class="flex items-center gap-2 bg-brand-orange hover:bg-brand-orange/90 text-white font-bold px-6 py-3 rounded-full shadow-xl hover:shadow-2xl transition-all text-sm"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
    </svg>
    Reserva tu Clase
  </a>
</div>

<script>
  const header = document.getElementById('main-header');
  const floatingCta = document.getElementById('floating-cta');

  window.addEventListener('scroll', () => {
    // Header shadow on scroll
    if (window.scrollY > 50) {
      header?.classList.add('shadow-md');
    } else {
      header?.classList.remove('shadow-md');
    }

    // Floating CTA appears after scrolling past hero (>90vh)
    if (window.scrollY > window.innerHeight * 0.9) {
      floatingCta?.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-4');
      floatingCta?.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');
    } else {
      floatingCta?.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
      floatingCta?.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
    }
  });

  // Mobile menu toggle
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
    });
  });
</script>
