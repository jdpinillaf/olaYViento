---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Hero from '../components/home/Hero.astro';
import Deportes from '../components/home/Deportes.astro';
import PorQueNosotros from '../components/home/PorQueNosotros.astro';
import Temporada from '../components/home/Temporada.astro';
import Galeria from '../components/home/Galeria.astro';
import Reservar from '../components/home/Reservar.astro';
import Ubicacion from '../components/home/Ubicacion.astro';
import FAQ from '../components/home/FAQ.astro';
import { buildLocalBusinessSchema, buildFAQSchema, buildOrganizationSchema, buildWebSiteSchema } from '../lib/schema';

const title = 'Ola y Viento | Escuela de Surf, Kitesurf y Wing Foil en Barranquilla';
const description = 'Escuela de deportes náuticos en Barranquilla, Colombia. Clases de surf, kitesurf, wing foil y SUP para todos los niveles. Instructores certificados, equipos incluidos. ¡Reserva hoy!';

const homeFaq = [
  { question: '¿Qué deportes náuticos enseñan en Ola y Viento?', answer: 'Ofrecemos clases de surf, kitesurf, wing foil, SUP y entrenamiento funcional.' },
  { question: '¿Necesito experiencia previa?', answer: 'No, todas nuestras clases son para todos los niveles, incluidos principiantes absolutos.' },
  { question: '¿Qué incluyen las clases?', answer: 'Equipamiento completo, instrucción profesional, teoría de seguridad y práctica en el agua.' },
  { question: '¿Cuál es la mejor época para deportes náuticos en Barranquilla?', answer: 'Diciembre a abril y junio a agosto para deportes de viento. Surf todo el año.' },
  { question: '¿Cómo reservo una clase?', answer: 'Por WhatsApp al +57 315 003 1693 o a través de nuestro sistema de reservas en línea.' },
];

const schemas = [
  buildOrganizationSchema(),
  buildWebSiteSchema(),
  buildLocalBusinessSchema(),
  buildFAQSchema(homeFaq),
];
---

<BaseLayout title={title} description={description} canonical="/" schemas={schemas}>
  <Header />
  <main id="main-content">
    <Hero />
    <Deportes />
    <PorQueNosotros />
    <Temporada />
    <Galeria />
    <Reservar />
    <Ubicacion />
    <FAQ />
  </main>
  <Footer />
</BaseLayout>
