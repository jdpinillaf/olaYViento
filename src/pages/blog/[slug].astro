---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { fetchPosts, type BlogPost } from '../../data/blog';
import { programmaticPages } from '../../data/pages';
import { getSportBySlug } from '../../data/sports';
import { buildBreadcrumbSchema, buildBlogPostSchema } from '../../lib/schema';

export async function getStaticPaths() {
  const posts = await fetchPosts();
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

const breadcrumbs = [
  { name: 'Inicio', url: '/' },
  { name: 'Blog', url: '/blog' },
  { name: post.title, url: `/blog/${post.slug}` },
];

const schemas = [
  buildBreadcrumbSchema(breadcrumbs),
  buildBlogPostSchema(post),
];

// Find related programmatic page for the sport
const relatedPage = post.sportSlug
  ? programmaticPages.find(p => p.sportSlug === post.sportSlug && p.tier === 1)
  : null;
const relatedSport = post.sportSlug ? getSportBySlug(post.sportSlug) : null;

// Portable Text rendering helpers
function renderBlock(block: any): string {
  if (block._type === 'block') {
    const text = (block.children || [])
      .map((child: any) => {
        let t = child.text || '';
        if (child.marks?.includes('strong')) t = `<strong>${t}</strong>`;
        if (child.marks?.includes('em')) t = `<em>${t}</em>`;
        if (child.marks?.includes('underline')) t = `<u>${t}</u>`;
        // Handle link marks
        const linkMark = child.marks?.find((m: string) => m !== 'strong' && m !== 'em' && m !== 'underline');
        if (linkMark && block.markDefs) {
          const def = block.markDefs.find((d: any) => d._key === linkMark);
          if (def?.href) t = `<a href="${def.href}" class="text-brand-blue hover:underline" target="_blank" rel="noopener noreferrer">${t}</a>`;
        }
        return t;
      })
      .join('');

    switch (block.style) {
      case 'h2': return `<h2 class="font-display text-2xl sm:text-3xl font-bold text-brand-dark mt-10 mb-4">${text}</h2>`;
      case 'h3': return `<h3 class="font-display text-xl sm:text-2xl font-bold text-brand-dark mt-8 mb-3">${text}</h3>`;
      case 'h4': return `<h4 class="font-display text-lg font-bold text-brand-dark mt-6 mb-2">${text}</h4>`;
      case 'blockquote': return `<blockquote class="border-l-4 border-brand-blue pl-4 italic text-gray-600 my-6">${text}</blockquote>`;
      default: return text ? `<p class="text-gray-600 leading-relaxed mb-4">${text}</p>` : '';
    }
  }

  if (block._type === 'image' && block.asset?._ref) {
    // For image blocks with asset references, we can't resolve URL at render time
    // This case is handled by Sanity CDN URL in the GROQ query if expanded
    return '';
  }

  return '';
}

function renderBlocks(blocks: any[]): string {
  if (!blocks) return '';
  const result: string[] = [];
  let listItems: string[] = [];
  let listType: string | null = null;

  for (const block of blocks) {
    if (block._type === 'block' && block.listItem) {
      const currentType = block.listItem === 'number' ? 'ol' : 'ul';
      if (listType && listType !== currentType) {
        const tag = listType;
        const cls = tag === 'ul' ? 'list-disc' : 'list-decimal';
        result.push(`<${tag} class="${cls} pl-6 mb-4 space-y-1 text-gray-600">${listItems.join('')}</${tag}>`);
        listItems = [];
      }
      listType = currentType;
      const text = (block.children || []).map((c: any) => c.text || '').join('');
      listItems.push(`<li>${text}</li>`);
    } else {
      if (listItems.length > 0) {
        const tag = listType === 'ol' ? 'ol' : 'ul';
        const cls = tag === 'ul' ? 'list-disc' : 'list-decimal';
        result.push(`<${tag} class="${cls} pl-6 mb-4 space-y-1 text-gray-600">${listItems.join('')}</${tag}>`);
        listItems = [];
        listType = null;
      }
      result.push(renderBlock(block));
    }
  }

  if (listItems.length > 0) {
    const tag = listType === 'ol' ? 'ol' : 'ul';
    const cls = tag === 'ul' ? 'list-disc' : 'list-decimal';
    result.push(`<${tag} class="${cls} pl-6 mb-4 space-y-1 text-gray-600">${listItems.join('')}</${tag}>`);
  }

  return result.join('');
}

const bodyHtml = renderBlocks(post.body || []);

const sportLabels: Record<string, string> = {
  surf: 'Surf',
  kitesurf: 'Kitesurf',
  'wing-foil': 'Wing Foil',
  sup: 'SUP',
};
---

<BaseLayout
  title={`${post.title} | Ola y Viento`}
  description={post.excerpt || post.title}
  canonical={`/blog/${post.slug}`}
  ogImage={post.mainImage || undefined}
  schemas={schemas}
>
  <Header />
  <main id="main-content" class="pt-20">
    <!-- Breadcrumb -->
    <nav class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-4" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-sm text-gray-500 flex-wrap">
        <li><a href="/" class="hover:text-brand-blue transition-colors">Inicio</a></li>
        <li><span class="mx-1">/</span></li>
        <li><a href="/blog" class="hover:text-brand-blue transition-colors">Blog</a></li>
        <li><span class="mx-1">/</span></li>
        <li><span class="text-brand-dark font-medium line-clamp-1">{post.title}</span></li>
      </ol>
    </nav>

    <!-- Article -->
    <article class="py-8 sm:py-12">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <header class="mb-8">
          <div class="flex items-center gap-3 mb-4">
            <time class="text-sm text-gray-400" datetime={post.publishedAt}>
              {new Date(post.publishedAt).toLocaleDateString('es-CO', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            {post.sportSlug && (
              <span class="text-xs bg-brand-blue/10 text-brand-blue px-2 py-0.5 rounded-full font-medium">
                {sportLabels[post.sportSlug] || post.sportSlug}
              </span>
            )}
          </div>
          <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-brand-dark mb-4">
            {post.title}
          </h1>
          {post.excerpt && (
            <p class="text-lg text-gray-500 leading-relaxed">{post.excerpt}</p>
          )}
        </header>

        <!-- Main Image -->
        {post.mainImage && (
          <div class="rounded-2xl overflow-hidden mb-10">
            <img
              src={post.mainImage}
              alt={post.title}
              class="w-full h-auto"
            />
          </div>
        )}

        <!-- Body -->
        <div class="prose-custom" set:html={bodyHtml} />

        <!-- Tags -->
        {post.tags && post.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-10 pt-6 border-t border-gray-200">
            {post.tags.map(tag => (
              <span class="text-xs bg-gray-100 text-gray-600 px-3 py-1 rounded-full">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </article>

    <!-- Related Sport CTA -->
    {relatedPage && relatedSport && (
      <section class="py-12 sm:py-16 bg-brand-yellow/10">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
          <span class="text-3xl mb-3 block">{relatedSport.icon}</span>
          <h2 class="font-display text-2xl font-bold text-brand-dark mb-3">
            ¿Listo para practicar {relatedSport.name}?
          </h2>
          <p class="text-gray-600 mb-6">
            Conoce nuestras clases de {relatedSport.name.toLowerCase()} y reserva tu sesión.
          </p>
          <a
            href={`/${relatedPage.slug}`}
            class="inline-flex items-center gap-2 bg-brand-orange hover:bg-brand-orange/90 text-white font-bold px-8 py-4 rounded-full transition-all hover:shadow-lg"
          >
            Ver clases de {relatedSport.name}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </section>
    )}

    <!-- Back to Blog -->
    <section class="py-8 bg-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <a href="/blog" class="inline-flex items-center gap-2 text-brand-blue hover:text-brand-blue/80 font-medium transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-5-5m0 0l5-5m-5 5h12" />
          </svg>
          Volver al Blog
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
