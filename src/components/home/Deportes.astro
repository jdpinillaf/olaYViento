---
import { sports } from '../../data/sports';

const sportPages: Record<string, string> = {
  'surf': '/clases-de-surf-barranquilla',
  'kitesurf': '/escuela-de-kitesurf-barranquilla',
  'wing-foil': '/wing-foil-barranquilla',
  'windsurf': '/windsurf-barranquilla',
  'sup': '/#reservar',
  'entrenamiento-funcional': '/#reservar',
};

// SVG icons for each sport (clean, professional look)
const sportIcons: Record<string, string> = {
  'surf': `<svg class="w-12 h-12" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 38c4-2 8-6 12-14s8-16 16-18c-2 8-6 12-14 16S10 34 8 38z" fill="currentColor" opacity="0.15"/><path d="M8 38c4-2 8-6 12-14s8-16 16-18c-2 8-6 12-14 16S10 34 8 38z"/><path d="M20 24l4-4" stroke-linecap="round"/></svg>`,
  'kitesurf': `<svg class="w-12 h-12" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2"><path d="M24 4L8 20h32L24 4z" fill="currentColor" opacity="0.15"/><path d="M24 4L8 20h32L24 4z"/><path d="M24 20v16M24 36l-4 6M24 36l4 6" stroke-linecap="round"/><path d="M16 42h16" stroke-linecap="round"/></svg>`,
  'wing-foil': `<svg class="w-12 h-12" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20c0-8 5-14 12-14s12 6 12 14" fill="currentColor" opacity="0.15"/><path d="M12 20c0-8 5-14 12-14s12 6 12 14"/><path d="M20 38h8M24 20v18" stroke-linecap="round"/><path d="M16 42c0-2 4-4 8-4s8 2 8 4" stroke-linecap="round"/></svg>`,
  'windsurf': `<svg class="w-12 h-12" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2"><path d="M24 8L14 36h20L24 8z" fill="currentColor" opacity="0.15"/><path d="M24 8L14 36h20L24 8z"/><path d="M24 36v6M18 42h12" stroke-linecap="round"/><path d="M24 8v28" stroke-linecap="round"/></svg>`,
  'sup': `<svg class="w-12 h-12" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="24" cy="36" rx="14" ry="4" fill="currentColor" opacity="0.15"/><ellipse cx="24" cy="36" rx="14" ry="4"/><path d="M24 36V16M24 16l-6 8M24 16l6 8" stroke-linecap="round"/></svg>`,
  'entrenamiento-funcional': `<svg class="w-12 h-12" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2"><circle cx="24" cy="12" r="4" fill="currentColor" opacity="0.15"/><circle cx="24" cy="12" r="4"/><path d="M24 16v12M18 22h12M14 28l10 12 10-12" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
};

// Gradient backgrounds per sport for visual variety
const sportGradients: Record<string, string> = {
  'surf': 'from-brand-blue/25 via-brand-blue/10 to-brand-yellow/15',
  'kitesurf': 'from-brand-orange/25 via-brand-orange/10 to-brand-blue/15',
  'wing-foil': 'from-brand-yellow/25 via-brand-yellow/10 to-brand-blue/15',
  'windsurf': 'from-brand-blue/20 via-brand-blue/10 to-brand-orange/15',
  'sup': 'from-brand-blue/15 via-brand-yellow/10 to-brand-orange/10',
  'entrenamiento-funcional': 'from-brand-orange/20 via-brand-yellow/10 to-brand-blue/10',
};
---

<section id="deportes" class="py-16 sm:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-brand-dark mb-3">
        Nuestros <span class="text-brand-blue">Deportes</span>
      </h2>
      <p class="text-gray-600 max-w-2xl mx-auto">
        Desde tus primeras olas hasta volar sobre el agua. Encuentra tu deporte acuático ideal.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {sports.map(sport => (
        <a
          href={sportPages[sport.slug] || '/#reservar'}
          class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 hover:border-brand-blue/30 hover:-translate-y-1"
        >
          <div class={`h-48 bg-gradient-to-br ${sportGradients[sport.slug] || 'from-brand-blue/20 to-brand-orange/20'} flex items-center justify-center relative overflow-hidden`}>
            <!-- Decorative swirl -->
            <svg class="absolute -bottom-4 -right-4 w-24 h-24 text-white/30" viewBox="0 0 100 100">
              <path d="M50 10 C70 10, 90 30, 90 50 C90 70, 70 90, 50 90 C30 90, 15 75, 20 55 C25 35, 40 30, 50 40" fill="none" stroke="currentColor" stroke-width="4"/>
            </svg>
            <div class="text-brand-blue group-hover:scale-110 transition-transform duration-300" set:html={sportIcons[sport.slug] || ''} />
          </div>
          <div class="p-6">
            <h3 class="font-display font-bold text-xl text-brand-dark group-hover:text-brand-blue transition-colors mb-2">
              {sport.name}
            </h3>
            <p class="text-gray-600 text-sm mb-4 leading-relaxed">
              {sport.shortDescription}
            </p>
            <div class="flex items-center justify-between">
              <span class="text-brand-orange font-semibold text-sm">{sport.price}</span>
              <span class="text-brand-blue text-sm font-medium group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
                Ver más
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
