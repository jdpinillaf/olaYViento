---
const usps = [
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>`,
    title: 'Instructores Certificados',
    description: 'Nuestro equipo cuenta con certificaciones internacionales y años de experiencia enseñando deportes acuáticos.',
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>`,
    title: 'Equipos Incluidos',
    description: 'Todo el equipamiento está incluido en cada clase. Tablas, velas, arneses, chalecos y más.',
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`,
    title: 'Todos los Niveles',
    description: 'Desde tu primera vez en el agua hasta perfeccionar maniobras avanzadas. Adaptamos cada clase a ti.',
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    title: 'Costa Caribe',
    description: 'Barranquilla ofrece vientos alisios, aguas cálidas y los mejores spots del Caribe colombiano.',
  },
];
---

<section id="nosotros" class="py-16 sm:py-24 bg-brand-blue">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mb-3">
        ¿Por qué <span class="text-brand-yellow">Ola y Viento</span>?
      </h2>
      <p class="text-white/80 max-w-2xl mx-auto">
        Somos la escuela de deportes acuáticos más completa de Barranquilla.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {usps.map(usp => (
        <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 text-center hover:bg-white/15 transition-colors">
          <div class="text-brand-yellow mb-4 flex justify-center" set:html={usp.icon} />
          <h3 class="font-display font-bold text-white text-lg mb-2">{usp.title}</h3>
          <p class="text-white/75 text-sm leading-relaxed">{usp.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
